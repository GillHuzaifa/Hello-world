<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- Force HTTP ---
  RewriteCond %{HTTP} off
  RewriteRule ^(.*)$ http://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # --- Angular SPA Routing ---
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>